# Copy to .env and fill in. .env is gitignored — never commit real keys.
#
# Optional: enable LangSmith tracing so runs show up in the LangSmith UI.
# Get a key at https://smith.langchain.com (free Developer plan: 5000 traces/mo).
# Leave LANGSMITH_TRACING=false to keep everything local (Studio still works).

LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=aiteam
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
